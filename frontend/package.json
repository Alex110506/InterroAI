{
  "name": "interro-ai",
  "version": "0.1.0",
  "description": "AI Multi-Agent Orchestration Platform",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently -k -n BACKEND,VITE,ELECTRON -c green,cyan,yellow \"cd ../backend && python3 -m uvicorn main:app --reload --port 8000\" \"vite\" \"wait-on http-get://localhost:8000/health http-get://localhost:5173 && NODE_ENV=development electron .\"",
    "build": "vite build",
    "backend": "cd ../backend && python3 -m uvicorn main:app --reload --port 8000",
    "electron": "NODE_ENV=development electron .",
    "start": "npm run dev"
  },
  "dependencies": {
    "lucide-react": "^0.400.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^32.0.0",
    "vite": "^5.3.1",
    "wait-on": "^7.2.0"
  }
}
